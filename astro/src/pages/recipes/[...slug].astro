---
import { getCollection } from 'astro:content';
import MarkdownRecipeLayout from "@layouts/MarkdownRecipeLayout.astro";

export async function getStaticPaths() {
  const recipeEntries = await getCollection('recipes');
  return recipeEntries.map(recipe => ({
    params: { slug: recipe.slug }, props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await recipe.render();
---

<MarkdownRecipeLayout frontmatter={recipe.data}>
    <Content />
    <a
      id="edit-button-template"
      aria-label="Editar receta"
      title="Editar receta"
      class="hidden fixed bottom-6 right-6 z-50 flex items-center justify-center rounded-full bg-primary p-4 text-white shadow-lg hover:bg-primary-accent focus:outline-none focus:ring-2 focus:ring-primary-accent focus:ring-offset-2"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-5 w-5"
      >
        <path d="M12 20h9" />
        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />
      </svg>
    </a>
    <script is:inline>
      const template = document.getElementById("edit-button-template");
      if (typeof window !== "undefined" && template && localStorage.getItem("tokens")) {
        const button = template.cloneNode(true);
        button.id = "";
        button.href = window.location.pathname.replace(/\/$/, "") + "/edit";
        button.classList.remove("hidden");
        document.body.appendChild(button);
      }
    </script>
</MarkdownRecipeLayout>