---
import { getCollection } from 'astro:content';
import Layout from "@layouts/BaseLayout.astro";
import RecipePage from "@solidcomponents/RecipePage";
import { adaptRecipes } from "@utils/recipesAdapter";
import { getTags } from "@utils/api";

let [recipes, tags] = await await Promise.all([
  getCollection('recipes'),
  getTags()
]);
recipes.sort((a, b) => a.data.cooking_time - b.data.cooking_time);
const recipesTyped = adaptRecipes(recipes);

---

<Layout pagename="home" title="Burnbook">
  <RecipePage recipes={recipesTyped} tags={tags} client:only="solid-js" />
</Layout>
