---
import { type RecipeIngredient } from "@utils/interfaces";

export interface Props {
  RecipeIngredients: Array<RecipeIngredient>;
}

const { RecipeIngredients = [] } = Astro.props;

function getUnitTranslated(unit) {
  let translateUnit = "";
  switch (unit) {
    case "tablespoon":
      translateUnit = "cucharada";
      break;
    case "teaspoon":
     translateUnit = "cucharilla";
      break;
    case "unit":
      translateUnit = "";
      break;
    default:
      translateUnit = unit;
      break;
  }
  return translateUnit;
}
function prefix(recipeIngredient: RecipeIngredient) {
  let recipePrefix = recipeIngredient?.ingredient?.prefix || "";
  recipePrefix = recipePrefix.toLowerCase()
  if (recipePrefix.endsWith(" "))
    return recipePrefix
  return `${recipePrefix} `;
}
function name(recipeIngredient: RecipeIngredient) {
  let recipeName = recipeIngredient?.ingredient?.name || "";
  return recipeName.toLowerCase()
}

function getIngredientText(recipeIngredient: RecipeIngredient) {
  let quantity : number = recipeIngredient?.quantity || 1;
  let ingredient_fullname : string = prefix(recipeIngredient) + name(recipeIngredient);
  let unit = recipeIngredient?.unit || "al_gusto";
  if (unit === "al_gusto") return `${ingredient_fullname} al gusto`;
  let translatedUnit = getUnitTranslated(unit);
  return `${quantity} ${translatedUnit} ${ingredient_fullname}`
}
---

<div class="ingredient text-lg">
  {
    RecipeIngredients.map((recipeIngredient, index) => (
      <label
        class="mb-4 flex items-center gap-3 cursor-pointer select-none"
      >
        <input
          type="checkbox"
          id={`ingredient-${index}`}
          name={recipeIngredient.ingredient.name}
          value={index}
          class="ingredient-checkbox"
        />
        <span class="ingredient-text">
          { getIngredientText(recipeIngredient) }
        </span>
      </label>
    ))
  }
</div>
<style>
  @reference "../../styles/global.css";

  .ingredient-checkbox {
    @apply relative w-5 h-5 shrink-0 cursor-pointer
           rounded-sm border border-gray-400
           bg-white
           transition-all duration-150 ease-out
           focus-visible:outline-none
           focus-visible:ring-2
           focus-visible:ring-secondary-dark-ring;
    
    appearance: none;
  }
  
  /* Checked state */
  .ingredient-checkbox:checked {
    @apply bg-primary border-primary;
  }
  
  /* Checkmark */
  .ingredient-checkbox::after {
    content: "";
    position: absolute;
    inset: 0;
    margin: auto;
    width: 0.35rem;
    height: 0.6rem;
    border-right: 2px solid white;
    border-bottom: 2px solid white;
    transform: rotate(45deg) scale(0);
    transition: transform 150ms ease-out;
  }
  
  /* Animate checkmark in */
  .ingredient-checkbox:checked::after {
    transform: rotate(45deg) scale(1);
  }
  
  /* Hover (mouse users only) */
  .ingredient-checkbox:hover {
    @apply border-primary;
  }
  
  /* Text spacing & click affordance */
  .ingredient-text {
    @apply leading-snug;
  }
</style>
