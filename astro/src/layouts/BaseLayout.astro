---
import "@styles/global.css";
import { getOptimizedImage } from "@utils/images/getOptimizedImage";

export interface Props {
	title: string;
	pagename: string;
	lcpImage: string;
}

const { 
	title,
	pagename,
	lcpImage
} = Astro.props;

const isDev = import.meta.env.DEV;
const crossOriginAttribute = isDev ? null : "anonymous";
const optimizeImages = import.meta.env.PUBLIC_OPTIMIZE_IMAGES || 0;
// ⚡ Resolve the optimized asset data during build time
const lcpImageData = lcpImage ? getOptimizedImage(lcpImage, "full") : null;
const lcpFallbackSrc = lcpImageData?.fallback?.srcSet;
---

<!DOCTYPE html>
<html lang="es" class={"bg-theme-background " + pagename}>
	<head>
		<meta charset="UTF-8" />
		<meta name="title" title={ title }/>
		<meta name="description" content="A collection of recipes we cook and love to share with other people.">
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="icon" type="image/png" sizes="128x128" href="/favicon-128x128.png">
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		{ optimizeImages && 
			<link rel="preconnect" href={process.env.PUBLIC_IMAGE_BASE} crossorigin={crossOriginAttribute}>
			<link rel="dns-prefetch" href={process.env.PUBLIC_IMAGE_BASE}>
		}
		{/* If there's an LCP candidate image, preload it immediately! */}
		{lcpFallbackSrc && (
			<link 
			rel="preload" 
			as="image" 
			href={lcpFallbackSrc} 
			fetchpriority="high"
			crossorigin={crossOriginAttribute}
			/>
		)}
		<title>{title}</title>
	</head>
	<body class="">
		<div class="antialiased">
			<slot />
		</div>
	</body>
</html>

